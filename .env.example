# Local development configuration. Copy to .env (`cp .env.example .env`).
# Deployed environments are configured via Terraform — see terraform/.

# URL the Express server binds to and advertises.
BASE_URL=http://localhost:3366

# Bearer token for the `Authorization: Bearer ...` header on protected routes.
ACCESS_TOKEN=asdf123

# Port for the local Express server.
PORT=3366

# Deployment topology. One of: local, dev, test. See src/config/appEnv.ts.
APP_ENV=local
