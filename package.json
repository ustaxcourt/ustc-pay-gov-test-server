{
  "name": "@ustaxcourt/ustc-pay-gov-test-server",
  "version": "0.2.4",
  "description": "USTC Pay.gov test server",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ustaxcourt/ustc-pay-gov-test-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npx tsc",
    "dev": "APP_ENV=local concurrently \"npx tsc --watch\" \"nodemon -q ./dist/server.js\"",
    "copy-files": "aws s3 cp src/static s3://dev-ustc-pay-gov-test-server --recursive",
    "test": "jest ./src",
    "test:coverage": "jest --coverage ./src",
    "start": "node .",
    "test:integration": "APP_ENV=local jest --verbose --bail ./test/integration",
    "test:integration:coverage": "APP_ENV=local jest --config jest.config.ts --coverage --testPathPatterns=integration",
    "test:integration:deployed": "DOTENV_CONFIG_PATH=.env.prod APP_ENV=dev jest --bail ./test/integration",
    "ci:publish": "changeset publish"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bin": {
    "start-pay-gov-test-server": "bin/start-pay-gov-test-server.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1092.0",
    "@types/aws-lambda": "^8.10.162",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.10.1",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "nodemon": "^3.1.14",
    "soap": "^1.10.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "cheerio": "^1.2.0",
    "concurrently": "9.2.4",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2"
  },
  "overrides": {
    "read-yaml-file": "^2.1.0",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^4.2.0"
    }
  }
}
